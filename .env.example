# =============================================================================
# .env.example — copy to .env and fill values to use an existing deployment.
# These are populated automatically when you run `azd provision`.
# =============================================================================

# ── Azure identity & scope ────────────────────────────────────────────────────
AZURE_ENV_NAME=cental_evals_dev
AZURE_LOCATION=eastus2
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_TENANT_ID=<your-tenant-id>
AZURE_PRINCIPAL_ID=<your-user-object-id>
AZURE_RESOURCE_GROUP=rg-<token>

# ── Function App ──────────────────────────────────────────────────────────────
FUNCTION_APP_NAME=func-<token>
AZURE_STORAGE_ACCOUNT=st<token>

# ── AI Services (judge model for quality evaluators) ─────────────────────────
AZURE_OPENAI_ENDPOINT=https://<ai-services-name>.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Log Analytics ingestion ───────────────────────────────────────────────────
LOG_ANALYTICS_WORKSPACE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.OperationalInsights/workspaces/<name>
DATA_COLLECTION_ENDPOINT_URI=https://<dce-name>.ingest.monitor.azure.com
DATA_COLLECTION_RULE_IMMUTABLE_ID=dcr-<id>

# ── Eval pack config ──────────────────────────────────────────────────────────
EVAL_PACK_VERSION=1.0.0
EVAL_SCORE_THRESHOLD=0.7
EVAL_ENABLE_QUALITY=true
EVAL_ENABLE_SAFETY=true
EVAL_ENABLE_SIMILARITY=true
# EVAL_DATASET_PATH=          # leave blank to use built-in baseline dataset
# EVAL_ROW_DELAY_SECONDS=2.0  # throttle between eval rows (default 2.0)
